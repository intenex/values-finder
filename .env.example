# Postgres connection string (Neon in production, local Postgres in dev).
POSTGRES_URL="postgresql://user:password@host:5432/database"

# Better Auth -----------------------------------------------------------------
# Long random string used to sign sessions and OAuth tokens. Generate with
# `openssl rand -base64 32`. SHARE THE SAME VALUE across every ecosystem app
# that delegates to this identity provider.
BETTER_AUTH_SECRET="generate-a-32+-char-random-secret"
# This app's own origin (the OAuth issuer). Per-environment.
BETTER_AUTH_URL="http://localhost:3000"
# Used by the browser auth client; usually the same as BETTER_AUTH_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Comma-separated client_ids that skip the consent screen (first-party apps).
OAUTH_TRUSTED_CLIENT_IDS=""

# Email (Resend) --------------------------------------------------------------
# Without a key, password-reset / verification links are logged to the server
# console instead of emailed (handy for local dev and CI).
RESEND_API_KEY=""
# Verified sending identity in Resend.
EMAIL_FROM="Deep Mindfulness <noreply@deepmindfulness.io>"
